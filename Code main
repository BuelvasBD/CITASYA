# ---------------------------------------------------
# CREAR TABLAS
# ---------------------------------------------------
def crear_tablas():
    conexion = sqlite3.connect(DB_NAME)
    cursor = conexion.cursor()

    cursor.execute("""
        CREATE TABLE IF NOT EXISTS usuarios (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            usuario TEXT UNIQUE NOT NULL,
            password TEXT NOT NULL,
            rol TEXT NOT NULL,
            npi TEXT,
            admin_code TEXT
        )
    """)

    cursor.execute("""
        CREATE TABLE IF NOT EXISTS citas (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            paciente TEXT NOT NULL,
            doctor TEXT NOT NULL,
            fecha TEXT NOT NULL,
            hora TEXT NOT NULL,
            motivo TEXT NOT NULL,
            estado TEXT NOT NULL DEFAULT 'Pendiente'
        )
    """)

    conexion.commit()
    conexion.close()

crear_tablas()

# ---------------------------------------------------
# FUNCIONES BD USUARIOS
# ---------------------------------------------------
def registrar_usuario(usuario, password, rol, npi=None, admin_code=None):
    conexion = sqlite3.connect(DB_NAME)
    cursor = conexion.cursor()

    try:
        cursor.execute("""
            INSERT INTO usuarios (usuario, password, rol, npi, admin_code)
            VALUES (?, ?, ?, ?, ?)
        """, (usuario, password, rol, npi, admin_code))

        conexion.commit()
        conexion.close()
        return True, None

    except sqlite3.IntegrityError:
        conexion.close()
        return False, "El usuario ya existe. Intenta con otro nombre."

    except Exception as e:
        conexion.close()
        return False, "Error del sistema: " + str(e)


def validar_login(usuario, password):
    conexion = sqlite3.connect(DB_NAME)
    cursor = conexion.cursor()

    cursor.execute("""
        SELECT usuario, rol, npi, admin_code 
        FROM usuarios 
        WHERE usuario = ? AND password = ?
    """, (usuario, password))

    resultado = cursor.fetchone()
    conexion.close()
    return resultado


def obtener_doctores():
    conexion = sqlite3.connect(DB_NAME)
    cursor = conexion.cursor()

    cursor.execute("SELECT usuario FROM usuarios WHERE rol = 'Medico'")
    doctores = cursor.fetchall()

    conexion.close()
    return doctores


def obtener_usuarios():
    conexion = sqlite3.connect(DB_NAME)
    cursor = conexion.cursor()

    cursor.execute("SELECT id, usuario, rol, npi, admin_code FROM usuarios ORDER BY id ASC")
    usuarios = cursor.fetchall()

    conexion.close()
    return usuarios


def eliminar_usuario(id_usuario):
    conexion = sqlite3.connect(DB_NAME)
    cursor = conexion.cursor()

    cursor.execute("DELETE FROM usuarios WHERE id = ?", (id_usuario,))
    conexion.commit()
    conexion.close()

