def crear_cita(paciente, doctor, fecha, hora, motivo):
    conexion = sqlite3.connect(DB_NAME)
    cursor = conexion.cursor()

    cursor.execute("""
        INSERT INTO citas (paciente, doctor, fecha, hora, motivo, estado)
        VALUES (?, ?, ?, ?, ?, 'Pendiente')
    """, (paciente, doctor, fecha, hora, motivo))

    conexion.commit()
    conexion.close()


def obtener_citas_paciente(paciente):
    conexion = sqlite3.connect(DB_NAME)
    cursor = conexion.cursor()

    cursor.execute("""
        SELECT doctor, fecha, hora, motivo, estado
        FROM citas
        WHERE paciente = ?
        ORDER BY fecha DESC, hora DESC
    """, (paciente,))

    citas = cursor.fetchall()
    conexion.close()
    return citas


def obtener_citas_pendientes_paciente(paciente):
    conexion = sqlite3.connect(DB_NAME)
    cursor = conexion.cursor()

    cursor.execute("""
        SELECT doctor, fecha, hora, motivo, estado
        FROM citas
        WHERE paciente = ? AND estado = 'Pendiente'
        ORDER BY fecha ASC, hora ASC
    """, (paciente,))

    citas = cursor.fetchall()
    conexion.close()
    return citas


def obtener_citas_doctor_hoy(doctor):
