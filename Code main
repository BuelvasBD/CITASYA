    cursor.execute("""
        SELECT paciente, fecha, hora, motivo, estado
        FROM citas
        WHERE doctor = ? AND fecha = ?
        ORDER BY hora ASC
    """, (doctor, hoy))

    citas = cursor.fetchall()
    conexion.close()
    return citas


