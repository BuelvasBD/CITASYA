def registrar_usuario(usuario, password, rol):
    conexion = sqlite3.connect(DB_NAME)
    cursor = conexion.cursor()

    try:
        cursor.execute(
            "INSERT INTO usuarios (usuario, password, rol) VALUES (?, ?, ?)",
            (usuario, password, rol)
        )
        conexion.commit()
        conexion.close()
        return True, None

    except sqlite3.IntegrityError:
        conexion.close()
        return False, "El usuario ya existe. Intenta con otro nombre."

    except Exception as e:
        conexion.close()
        return False, "Error del sistema: " + str(e)


def validar_login(usuario, password):
    conexion = sqlite3.connect(DB_NAME)
    cursor = conexion.cursor()

    cursor.execute(
        "SELECT usuario, rol FROM usuarios WHERE usuario = ? AND password = ?",
        (usuario, password)
    )

    resultado = cursor.fetchone()
    conexion.close()

    return resultado


def obtener_doctores():
    conexion = sqlite3.connect(DB_NAME)
    cursor = conexion.cursor()

    cursor.execute("SELECT usuario FROM usuarios WHERE rol = 'Medico'")
    doctores = cursor.fetchall()

    conexion.close()
    return doctores


def crear_cita(paciente, doctor, fecha, hora, motivo):
    conexion = sqlite3.connect(DB_NAME)
    cursor = conexion.cursor()

    cursor.execute("""
        INSERT INTO citas (paciente, doctor, fecha, hora, motivo, estado)
        VALUES (?, ?, ?, ?, ?, 'Pendiente')
    """, (paciente, doctor, fecha, hora, motivo))

    conexion.commit()
    conexion.close()


def obtener_citas_paciente(paciente):
    conexion = sqlite3.connect(DB_NAME)
    cursor = conexion.cursor()

    cursor.execute("""
        SELECT doctor, fecha, hora, motivo, estado
        FROM citas
        WHERE paciente = ?
        ORDER BY fecha DESC, hora DESC
    """, (paciente,))

    citas = cursor.fetchall()
    conexion.close()
    return citas


def obtener_citas_pendientes_paciente(paciente):
    conexion = sqlite3.connect(DB_NAME)
    cursor = conexion.cursor()

    cursor.execute("""
        SELECT doctor, fecha, hora, motivo, estado
        FROM citas
        WHERE paciente = ? AND estado = 'Pendiente'
        ORDER BY fecha ASC, hora ASC
    """, (paciente,))

    citas = cursor.fetchall()
    conexion.close()
    return citas


def obtener_citas_doctor_hoy(doctor):
    hoy = date.today().strftime("%Y-%m-%d")

    conexion = sqlite3.connect(DB_NAME)
    cursor = conexion.cursor()

    cursor.execute("""
        SELECT paciente, fecha, hora, motivo, estado
        FROM citas
        WHERE doctor = ? AND fecha = ?
        ORDER BY hora ASC
    """, (doctor, hoy))

    citas = cursor.fetchall()
    conexion.close()
    return citas


def obtener_proximas_citas_doctor(doctor):
    hoy = date.today().strftime("%Y-%m-%d")

    conexion = sqlite3.connect(DB_NAME)
    cursor = conexion.cursor()

    cursor.execute("""
        SELECT paciente, fecha, hora, motivo, estado
        FROM citas
        WHERE doctor = ? AND fecha >= ?
        ORDER BY fecha ASC, hora ASC
    """, (doctor, hoy))

    citas = cursor.fetchall()
    conexion.close()
    return citas


