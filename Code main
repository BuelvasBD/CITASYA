# ---------------------------------------------------
# RESUMEN ADMIN
# ---------------------------------------------------
def obtener_resumen_admin():
    conexion = sqlite3.connect(DB_NAME)
    cursor = conexion.cursor()

    cursor.execute("SELECT COUNT(*) FROM usuarios")
    total_usuarios = cursor.fetchone()[0]

    cursor.execute("SELECT COUNT(*) FROM usuarios WHERE rol = 'Paciente'")
    total_pacientes = cursor.fetchone()[0]

    cursor.execute("SELECT COUNT(*) FROM usuarios WHERE rol = 'Medico'")
    total_medicos = cursor.fetchone()[0]

    cursor.execute("SELECT COUNT(*) FROM citas")
    total_citas = cursor.fetchone()[0]

    cursor.execute("SELECT COUNT(*) FROM citas WHERE estado = 'Pendiente'")
    citas_pendientes = cursor.fetchone()[0]

    conexion.close()

    return total_usuarios, total_pacientes, total_medicos, total_citas, citas_pendientes

