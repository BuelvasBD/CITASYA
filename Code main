@app.route("/", methods=["GET", "POST"])
def login():
    error = None
    success = request.args.get("success")

    if request.method == "POST":
        usuario = request.form.get("usuario")
        password = request.form.get("password")

        resultado = validar_login(usuario, password)

        if resultado != None:
            session["usuario"] = resultado[0]
            session["rol"] = resultado[1]
            return redirect(url_for("dashboard"))
        else:
            error = "Usuario o contraseña incorrectos. Intenta nuevamente."

    return render_template_string(LOGIN_HTML, error=error, success=success)


@app.route("/register", methods=["GET", "POST"])
def register():
    error = None

    if request.method == "POST":
        usuario = request.form.get("usuario")
        password = request.form.get("password")
        rol = request.form.get("rol")

        if usuario == "" or password == "" or rol == "":
            error = "Todos los campos son obligatorios."
        else:
            registrado, mensaje = registrar_usuario(usuario, password, rol)

            if registrado:
                return redirect(url_for("login", success="Registro exitoso. Ahora puedes iniciar sesión."))
            else:
                error = mensaje

    return render_template_string(REGISTER_HTML, error=error)


@app.route("/dashboard")
def dashboard():
    if "usuario" not in session:
        return redirect(url_for("login"))

    usuario = session["usuario"]
    rol = session["rol"]

    doctores = obtener_doctores()
    historial = obtener_citas_paciente(usuario)
    pendientes = obtener_citas_pendientes_paciente(usuario)

    hoy = obtener_citas_doctor_hoy(usuario)
    proximas = obtener_proximas_citas_doctor(usuario)

    mensaje = request.args.get("msg")

    return render_template_string(
        DASHBOARD_HTML,
        usuario=usuario,
        rol=rol,
        doctores=doctores,
        historial=historial,
        pendientes=pendientes,
        hoy=hoy,
        proximas=proximas,
        mensaje=mensaje
    )


@app.route("/agendar", methods=["POST"])
def agendar():
    if "usuario" not in session:
        return redirect(url_for("login"))

    if session["rol"] != "Paciente":
        return redirect(url_for("dashboard"))

    paciente = session["usuario"]
    doctor = request.form.get("doctor")
    fecha = request.form.get("fecha")
    hora = request.form.get("hora")
    motivo = request.form.get("motivo")

    if doctor == "" or fecha == "" or hora == "" or motivo == "":
        return redirect(url_for("dashboard", msg="Todos los campos son obligatorios."))

    crear_cita(paciente, doctor, fecha, hora, motivo)
    return redirect(url_for("dashboard", msg="Cita agendada exitosamente."))


@app.route("/logout")
def logout():
    session.pop("usuario", None)
    session.pop("rol", None)
    return redirect(url_for("login"))


if __name__ == "__main__":
    app.run(debug=True)
